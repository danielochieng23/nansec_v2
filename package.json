{
  "name": "nangsec",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "css": "tailwindcss -i ./tailwind/input.css -o ./public/css/styles.css",
    "css:watch": "tailwindcss -i ./tailwind/input.css -o ./public/css/styles.css --watch",
    "start": "node server/index.js",
    "dev": "concurrently \"npm run css:watch\" \"node --watch server/index.js\"",
    "predev": "npm run css",
    "prestart": "npm run css"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "ejs": "^3.1.10",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4"
  }
}
