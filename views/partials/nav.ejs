<header class="sticky top-0 z-50 border-b border-zinc-200/90 bg-white/90 backdrop-blur-xl supports-[backdrop-filter]:bg-white/80">
  <div class="container flex h-[72px] items-center justify-between gap-4">
    <a href="/" class="group flex items-center gap-3 font-semibold tracking-tight text-zinc-900">
      <span class="flex h-10 w-10 items-center justify-center rounded-md border border-red-200 bg-white font-mono text-sm text-primary shadow-sm">NS</span>
      <span class="hidden flex-col text-sm leading-tight sm:flex">
        <span>Nangsec Technologies</span>
        <span class="text-[10px] font-normal uppercase tracking-[0.18em] text-zinc-500">Cybersecurity</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex">
      <a href="/" class="rounded-md px-3 py-2 text-sm font-medium transition <%= currentPath === '/' ? 'bg-red-50 text-primary' : 'text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900' %>">Home</a>

      <details class="relative group">
        <summary class="list-none cursor-pointer rounded-md px-3 py-2 text-sm font-medium text-zinc-600 transition marker:content-none hover:bg-zinc-100 hover:text-zinc-900 [&::-webkit-details-marker]:hidden <%= currentPath.startsWith('/services') ? 'bg-red-50 text-primary' : '' %>">
          <span class="inline-flex items-center gap-1">Services <svg class="h-4 w-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></span>
        </summary>
        <div class="absolute left-0 top-full z-50 mt-2 w-[min(100vw-2rem,380px)] rounded-xl border border-zinc-200 bg-white p-3 shadow-xl ring-1 ring-zinc-100">
          <p class="mb-2 px-2 text-[11px] font-semibold uppercase tracking-widest text-zinc-500">Practice areas</p>
          <ul class="grid gap-1 text-sm">
            <li><a class="block rounded-lg px-3 py-2.5 text-zinc-700 hover:bg-red-50" href="/services#assessment">Security Assessment</a></li>
            <li><a class="block rounded-lg px-3 py-2.5 text-zinc-700 hover:bg-red-50" href="/services#managed">Managed Security</a></li>
            <li><a class="block rounded-lg px-3 py-2.5 text-zinc-700 hover:bg-red-50" href="/services#specialized">Specialized Programs</a></li>
            <li><a class="block rounded-lg px-3 py-2.5 text-zinc-700 hover:bg-red-50" href="/services#compliance">Compliance &amp; Advisory</a></li>
            <li class="mt-1 border-t border-zinc-100 pt-2"><a class="block rounded-lg px-3 py-2 font-semibold text-primary hover:bg-zinc-50" href="/services">All services →</a></li>
          </ul>
        </div>
      </details>

      <a href="/training" class="rounded-md px-3 py-2 text-sm font-medium transition <%= currentPath.startsWith('/training') ? 'bg-red-50 text-primary' : 'text-zinc-600 hover:bg-zinc-100' %>">Training</a>
      <a href="/research" class="rounded-md px-3 py-2 text-sm font-medium transition <%= currentPath.startsWith('/research') ? 'bg-red-50 text-primary' : 'text-zinc-600 hover:bg-zinc-100' %>">Research</a>
      <a href="/resources" class="rounded-md px-3 py-2 text-sm font-medium transition <%= currentPath.startsWith('/resources') ? 'bg-red-50 text-primary' : 'text-zinc-600 hover:bg-zinc-100' %>">Resources</a>
      <a href="/company" class="rounded-md px-3 py-2 text-sm font-medium transition <%= currentPath.startsWith('/company') ? 'bg-red-50 text-primary' : 'text-zinc-600 hover:bg-zinc-100' %>">Company</a>
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a href="/contact" class="text-sm font-medium text-zinc-600 hover:text-zinc-900">Contact</a>
      <a href="/contact" class="rounded-md bg-primary px-3 py-2 text-sm font-semibold text-white shadow-md shadow-red-200/60 hover:bg-red-600">Schedule a call</a>
    </div>

    <button type="button" id="navToggle" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-zinc-200 bg-white text-zinc-800 shadow-sm lg:hidden" aria-label="Menu">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <div id="mobileNav" class="hidden border-t border-zinc-200 bg-white lg:hidden">
    <div class="container grid gap-1 py-4">
      <a class="rounded-md px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-50" href="/">Home</a>
      <a class="rounded-md px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-50" href="/services">Services</a>
      <a class="rounded-md px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-50" href="/training">Training</a>
      <a class="rounded-md px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-50" href="/research">Research</a>
      <a class="rounded-md px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-50" href="/resources">Resources</a>
      <a class="rounded-md px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-50" href="/company">Company</a>
      <a class="mt-2 rounded-md bg-primary px-3 py-2 text-center text-sm font-semibold text-white" href="/contact">Schedule a call</a>
    </div>
  </div>
</header>
