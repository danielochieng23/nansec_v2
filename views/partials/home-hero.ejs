<section class="relative flex min-h-svh flex-col overflow-hidden border-b border-zinc-900">
  <div class="absolute inset-0 z-0">
    <img src="<%= siteImages.hero %>" alt="Cybersecurity analyst reviewing system defenses in a secure operations setting" class="absolute inset-0 h-full w-full object-cover object-[center_22%] sm:object-center" fetchpriority="high" />
    <div class="absolute inset-0 bg-zinc-950/86"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/72 via-zinc-950/45 to-red-950/22"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_90%_60%_at_70%_20%,rgba(220,38,38,0.14),transparent_55%)]"></div>
  </div>

  <%- include('./hero-cyber-backdrop') %>

  <div class="relative z-10 flex min-h-0 flex-1 flex-col justify-center">
    <div class="container max-w-7xl pt-28 pb-16 md:pt-32 md:pb-24">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-red-500/45 bg-red-950/60 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-red-200 backdrop-blur-sm">
          Pan-African cybersecurity practice
        </div>
        <h1 class="mt-8 text-pretty text-4xl font-semibold leading-[1.08] tracking-tight text-white md:text-5xl lg:text-6xl">
          Security built for how your organization <span class="text-red-400">ships and scales</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-zinc-300 md:text-xl">
          Nangsec helps teams design, validate, and operate defenses that respect your risk appetite, your regulatory reality, and the skills you already have on staff.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn-primary">
            Talk to our team
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/company" class="btn-outline-hero">Who we are</a>
        </div>
      </div>

      <div class="mt-14 grid gap-6 border-t border-white/10 pt-10 sm:grid-cols-3">
        <div class="flex gap-3">
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="text-sm font-semibold text-zinc-100">Regional delivery</p>
            <p class="text-sm text-zinc-400">Engagements coordinated across West and East Africa with remote-first experts.</p>
          </div>
        </div>
        <div class="flex gap-3">
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <div>
            <p class="text-sm font-semibold text-zinc-100">Sector experience</p>
            <p class="text-sm text-zinc-400">Finance, telecom, energy, SaaS, and public institutions—we map controls to your sector.</p>
          </div>
        </div>
        <div class="flex gap-3">
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
          <div>
            <p class="text-sm font-semibold text-zinc-100">Modern stacks</p>
            <p class="text-sm text-zinc-400">Hybrid, multi-cloud, and Kubernetes-heavy estates are our everyday baseline.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
