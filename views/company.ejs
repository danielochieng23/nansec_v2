<%- include('partials/head-open') %>
<%- include('partials/nav') %>

<main class="bg-zinc-50">
  <%- include('partials/page-hero', { heroEyebrow: 'Company', heroTitle: title, heroLead: description, heroImage: siteImages.companyTeam, heroImageAlt: 'Security and technology team collaborating on priorities' }) %>

  <section class="border-b border-zinc-200 bg-white py-14">
    <div class="container">
      <div class="grid gap-8 lg:grid-cols-2 lg:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">At a glance</p>
          <h2 class="mt-3 text-2xl font-semibold text-zinc-900 md:text-3xl">A practitioner-led firm with regional hubs</h2>
          <p class="mt-4 text-sm leading-relaxed text-zinc-600">We pair local context with methods borrowed from global finance, cloud-native builders, and critical infrastructure—then tune delivery to how your teams actually ship.</p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <% [{ n: "3", l: "Hub cities for delivery & training" },{ n: "120+", l: "Assessments & remediation programs completed" },{ n: "35+", l: "Long-running client relationships" },{ n: '<1h', l: "P1 acknowledgement target on retainer" }].forEach(function (s) { %>
          <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-5 text-center">
            <p class="text-2xl font-semibold text-primary md:text-3xl"><%= s.n %></p>
            <p class="mt-1 text-xs leading-snug text-zinc-600"><%= s.l %></p>
          </div>
          <% }); %>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-zinc-200 py-16 md:py-24">
    <div class="container">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">How we operate</p>
      <h2 class="mt-2 text-2xl font-semibold text-zinc-900 md:text-3xl">Mission, leadership, people, partners</h2>
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        <% const blocks = [
          { title: "Mission", desc: "Help African enterprises and public institutions adopt security capabilities that survive board scrutiny, auditor review, and day-to-day shipping pressure—not slide-deck narratives alone.", points: ["Outcomes over vanity metrics", "Shared backlog with engineering"] },
          { title: "Leadership", desc: "Executives stay close to methodologies, staffing, and escalations instead of hiding behind opaque account layers.", points: ["Named escalation paths", "Quarterly methodology reviews"] },
          { title: "Careers", desc: "We hire testers, detection engineers, responders, and advisors who want accountability for outcomes—beyond ticket throughput.", points: ["Live environment time", "Mentorship across hubs"] },
          { title: "Partners", desc: "Cloud providers, universities, and niche vendors join when they improve outcomes—never as mandatory resale.", points: ["Co-developed training", "Joint reference architectures"] },
        ]; %>
        <% blocks.forEach(function (b) { %>
        <div class="rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm transition hover:border-red-200">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg border border-zinc-100 bg-zinc-50 text-primary">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-zinc-900"><%= b.title %></h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-600"><%= b.desc %></p>
          <ul class="mt-6 space-y-2 text-xs text-zinc-500">
            <% b.points.forEach(function (p) { %>
            <li class="flex gap-2"><span class="text-primary">—</span><%= p %></li>
            <% }); %>
          </ul>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden border-b border-red-100 bg-gradient-to-r from-red-50 via-white to-red-50 py-16">
    <div class="container grid gap-10 lg:grid-cols-2 lg:items-center">
      <div class="overflow-hidden rounded-2xl border border-red-100 shadow-md">
        <img src="<%= siteImages.companyTeam %>" alt="Collaboration across our hubs" class="aspect-[16/10] w-full object-cover" loading="lazy" />
      </div>
      <div>
        <h2 class="text-2xl font-semibold text-zinc-900 md:text-3xl">Clients &amp; references</h2>
        <p class="mt-4 text-sm leading-relaxed text-zinc-600">Teams invite us when reporting must hold up to regulators, insurers, and technical owners simultaneously. We align reference conversations with your sector and stack once NDAs are in place.</p>
        <ul class="mt-6 space-y-3 text-sm text-zinc-600">
          <li class="flex gap-2"><span class="font-medium text-zinc-800">Finance &amp; payments</span> — shared control language with engineering and GRC</li>
          <li class="flex gap-2"><span class="font-medium text-zinc-800">Infrastructure &amp; energy</span> — uptime-aware testing and response drills</li>
          <li class="flex gap-2"><span class="font-medium text-zinc-800">SaaS &amp; platforms</span> — continuous assurance aligned to release tempo</li>
        </ul>
        <a href="/contact" class="btn-primary mt-8 inline-flex w-fit">Start a reference request</a>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot-close') %>
