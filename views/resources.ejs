<%- include('partials/head-open') %>
<%- include('partials/nav') %>

<main class="bg-white">
  <%- include('partials/page-hero', { heroEyebrow: 'Resources', heroTitle: title, heroLead: description, heroImage: siteImages.resourcesDocs, heroImageAlt: 'Technical documentation and guides for security teams' }) %>

  <section class="bg-zinc-50 py-16 md:py-24">
    <div class="container">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% const cards = [
          { type: "Case write-up", title: "Shrinking dwell time in a payments integration layer", desc: "How one team closed visibility gaps by sequencing logging investments." },
          { type: "Article", title: "Threat modeling APIs when traffic is spikey", desc: "A concise pattern language for engineers who need practical controls." },
          { type: "Walkthrough", title: "Purple exercise: stolen creds to cloud persistence", desc: "Lab notes with mitigations cross-walked to common control libraries." },
          { type: "Case write-up", title: "SOC uplift without doubling analyst headcount", desc: "Automation, tier design, and leadership metrics for multi-country logistics." },
          { type: "Article", title: "Incident communications that survive regulatory glare", desc: "Sequencing legal, customer, and investor updates under pressure." },
          { type: "Walkthrough", title: "Kubernetes admission hardening in practical slices", desc: "Checklists sized for sprint work—ship improvements every week." },
        ]; %>
        <% cards.forEach(function (c) { %>
        <article class="group flex flex-col rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm transition hover:border-red-200 hover:shadow-md">
          <div class="mb-4 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-zinc-500"><%= c.type %></div>
          <h2 class="text-lg font-semibold text-zinc-900"><%= c.title %></h2>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-zinc-600"><%= c.desc %></p>
          <a href="/contact" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-primary group-hover:text-red-800">Ask for the full piece ↗</a>
        </article>
        <% }); %>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot-close') %>
