<%- include('partials/head-open') %>
<%- include('partials/nav') %>

<main class="bg-white">
  <%- include('partials/page-hero', { heroEyebrow: 'Resources', heroTitle: title, heroLead: description, heroImage: siteImages.resourcesDocs, heroImageAlt: 'Technical documentation and guides for security teams' }) %>

  <section class="border-b border-zinc-200 bg-zinc-950 py-12 text-zinc-300">
    <div class="container">
      <div class="grid gap-8 md:grid-cols-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-red-400">Purpose</p>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">Summaries you can forward in the same thread to engineering and risk—terminology matches how we deliver work.</p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-red-400">Formats</p>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">Case write-ups, long-form articles, and step-by-step walkthroughs with control cross-walks your auditors already recognize.</p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-red-400">Access</p>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">Many pieces are client-shared under NDA. Ask for a bundle matched to your sector—we often curate three to five starting articles.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="relative border-b border-zinc-200 bg-zinc-50 py-16 md:py-20">
    <div class="pointer-events-none absolute bottom-0 right-0 top-0 w-1/3 max-w-md bg-gradient-to-l from-red-50/50 to-transparent"></div>
    <div class="relative container">
      <div class="mb-10 flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">Library</p>
          <h2 class="mt-2 text-2xl font-semibold text-zinc-900 md:text-3xl">Featured topics</h2>
          <p class="mt-2 max-w-xl text-sm text-zinc-600">Illustrative titles—we tailor reading lists after a short scoping call.</p>
        </div>
        <a href="/contact" class="text-sm font-semibold text-primary hover:text-red-800">Request a curated pack →</a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% const cards = [
          { type: "Case write-up", title: "Shrinking dwell time in a payments integration layer", desc: "How one team closed visibility gaps by sequencing logging investments instead of buying another black box.", read: "12 min", focus: "Detection & logging" },
          { type: "Article", title: "Threat modeling APIs when traffic is spikey", desc: "A concise pattern language for engineers who need practical controls, not a forty-page STRIDE essay.", read: "8 min", focus: "App security" },
          { type: "Walkthrough", title: "Purple exercise: stolen creds to cloud persistence", desc: "Lab notes with mitigations cross-walked to common control libraries your auditors recognize.", read: "15 min", focus: "Cloud & identity" },
          { type: "Case write-up", title: "SOC uplift without doubling analyst headcount", desc: "Automation, tier design, and leadership metrics for logistics across multiple countries.", read: "11 min", focus: "SOC operations" },
          { type: "Article", title: "Incident communications under regulatory glare", desc: "Sequencing legal, customer, and investor updates so technical facts stay consistent.", read: "9 min", focus: "Leadership" },
          { type: "Walkthrough", title: "Kubernetes admission hardening in slices", desc: "Checklists sized for sprint work—platform teams ship improvements weekly, not annually.", read: "14 min", focus: "Platform security" },
        ]; %>
        <% cards.forEach(function (c) { %>
        <article class="group flex flex-col overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm transition hover:border-red-200 hover:shadow-md">
          <div class="border-b border-zinc-100 bg-zinc-50/80 px-6 py-4">
            <span class="text-xs font-semibold uppercase tracking-widest text-zinc-500"><%= c.type %></span>
            <p class="mt-1 text-[11px] text-zinc-400"><%= c.focus %> · <%= c.read %> read</p>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h2 class="text-lg font-semibold leading-snug text-zinc-900"><%= c.title %></h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-zinc-600"><%= c.desc %></p>
            <a href="/contact" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-primary group-hover:gap-2">Ask for the full piece ↗</a>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot-close') %>
