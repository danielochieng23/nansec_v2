<%- include('partials/head-open') %>
<%- include('partials/nav') %>

<main>
  <%- include('partials/home-hero') %>

  <section class="border-b border-zinc-200 bg-zinc-50 py-16 md:py-24">
    <div class="container">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">What we do</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-zinc-900 md:text-4xl">Programs shaped to your industry and estate</h2>
        <p class="mt-4 text-zinc-600">Mix project work, recurring testing, and managed operations—so leadership sees continuity instead of one-off PDF drops.</p>
      </div>
      <div class="relative mx-auto mt-10 aspect-[2.2/1] w-full max-w-5xl overflow-hidden rounded-2xl border border-zinc-200 shadow-md">
        <img src="<%= siteImages.networkAbstract %>" alt="Abstract network nodes representing interconnected systems under security monitoring" class="h-full w-full object-cover" loading="lazy" />
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        <% const solutions = [
          { t: "Offensive & defensive assessment", d: "Structured testing for web systems, mobile apps, APIs, networks, and cloud footprints—with remediation support." },
          { t: "Industrial & embedded systems", d: "Reviews for plants, utilities, and other uptime-sensitive environments where safety and availability dominate." },
          { t: "Governance & compliance", d: "ISO-style, sector, and privacy regimes translated into engineering tasks your teams can actually schedule." },
          { t: "Managed detection & response", d: "Continuous monitoring, tuned detections, and escalation paths that match your internal ownership model." },
          { t: "Targeted programs", d: "Crisis exercises, adversary emulation, executive briefings, and tabletop sessions when stakes spike." },
          { t: "Embedded expertise", d: "Fractional leads and specialists so you can scale capacity without long hiring cycles or hollow vendor benches." },
          { t: "Investigation & recovery", d: "Structured incident work—from first response through evidence handling—to stabilize and learn from events." },
        ]; %>
        <% solutions.forEach(function (s) { %>
        <div class="group relative overflow-hidden rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm transition hover:border-red-200 hover:shadow-md">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg border border-zinc-100 bg-zinc-50 text-primary transition group-hover:border-red-100 group-hover:bg-red-50">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-zinc-900"><%= s.t %></h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-600"><%= s.d %></p>
          <a href="/services" class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-red-700">View services <span aria-hidden="true">→</span></a>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="border-b border-zinc-200 py-14">
    <div class="container">
      <div class="mb-8 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">Organizations we support</p>
          <h2 class="text-2xl font-semibold text-zinc-900 md:text-3xl">Teams that treat security as infrastructure, not a slide deck</h2>
        </div>
        <a href="/company" class="text-sm font-semibold text-primary hover:text-red-700">Learn about our work →</a>
      </div>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-6">
        <% for (let i = 0; i < 6; i++) { %>
        <div class="flex items-center justify-center rounded-xl border border-zinc-200 bg-white px-4 py-6 text-xs font-semibold uppercase tracking-widest text-zinc-400 shadow-sm">Partner</div>
        <% } %>
      </div>
    </div>
  </section>

  <section class="border-b border-red-100 bg-gradient-to-b from-red-50/80 to-white py-14">
    <div class="container">
      <div class="grid gap-8 md:grid-cols-4 text-center md:text-left">
        <% [{ n: "120+", l: "Completed assessments & remediation programs" },{ n: "35+", l: "Organizations with long-running engagements" },{ n: "<1h", l: "Target acknowledgement for P1 incidents on retainer" },{ n: "3", l: "Regional hubs supporting delivery and training" }].forEach(function (s) { %>
        <div>
          <p class="text-4xl font-semibold tracking-tight text-primary md:text-5xl"><%= s.n %></p>
          <p class="mt-2 text-sm text-zinc-600"><%= s.l %></p>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="border-b border-zinc-200 bg-zinc-50 py-16 md:py-24">
    <div class="container">
      <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div class="max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">Featured offerings</p>
          <h2 class="mt-2 text-3xl font-semibold text-zinc-900 md:text-4xl">From first test to continuous monitoring</h2>
          <p class="mt-3 text-zinc-600">Each line of business below connects to named deliverables and follow-up—you always know what “done” looks like.</p>
        </div>
        <a href="/services" class="inline-flex items-center gap-2 font-semibold text-zinc-900 hover:text-primary">Full service list →</a>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <% const featured = [
          { title: "Penetration testing", desc: "Scoped adversarial testing for customer-facing apps, internal tools, and supporting infrastructure.", img: siteImages.servicesHero, alt: "Digital technology abstract — assessment and testing context" },
          { title: "Managed SOC partnership", desc: "Shared responsibility for alert triage, tuning, and escalation according to your internal ownership.", img: siteImages.socOperations, alt: "Operations room style security monitoring and response" },
          { title: "Threat intelligence briefings", desc: "Regional and sector-specific reporting with indicators your blue team can plug in quickly.", img: siteImages.cloudSecurity, alt: "Global digital infrastructure representing visibility coverage" },
        ]; %>
        <% featured.forEach(function (card) { %>
        <article class="overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm transition hover:border-red-200 hover:shadow-md">
          <div class="relative aspect-[16/10] w-full">
            <img src="<%= card.img %>" alt="<%= card.alt %>" class="h-full w-full object-cover" loading="lazy" />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-semibold text-zinc-900"><%= card.title %></h3>
            <p class="mt-3 text-sm leading-relaxed text-zinc-600"><%= card.desc %></p>
            <a href="/services" class="mt-6 inline-block text-sm font-semibold text-primary hover:text-red-700">Details →</a>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="border-b border-zinc-200 py-16 md:py-20">
    <div class="container grid gap-8 lg:grid-cols-2">
      <div class="flex flex-col overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm">
        <div class="relative aspect-[16/9] w-full shrink-0">
          <img src="<%= siteImages.trainingLab %>" alt="Hands-on cybersecurity training" class="h-full w-full object-cover" loading="lazy" />
        </div>
        <div class="relative p-8 md:p-10">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">Training</p>
          <h2 class="mt-3 text-2xl font-semibold text-zinc-900 md:text-3xl">Skills programs for analysts, builders, and leaders</h2>
          <p class="mt-3 text-zinc-600">Hands-on cohorts and private classes that connect classroom lessons to tickets your team already files.</p>
          <a href="/training" class="btn-primary mt-8 inline-flex w-fit">Training catalog</a>
        </div>
      </div>
      <div class="flex flex-col overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-50 shadow-sm">
        <div class="relative aspect-[16/9] w-full shrink-0">
          <img src="<%= siteImages.researchDesk %>" alt="Security research workspace" class="h-full w-full object-cover" loading="lazy" />
        </div>
        <div class="relative p-8 md:p-10">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">Research</p>
          <h2 class="mt-3 text-2xl font-semibold text-zinc-900 md:text-3xl">Notes and tooling from the field</h2>
          <p class="mt-3 text-zinc-600">Short studies, advisories, and lightweight utilities informed by investigations and testing.</p>
          <a href="/research" class="mt-8 inline-flex items-center justify-center rounded-md border border-zinc-300 bg-white px-5 py-2.5 text-sm font-semibold text-zinc-900 hover:bg-zinc-50">Browse outputs</a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-zinc-200 bg-zinc-50 py-16 md:py-24">
    <div class="container grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">How we grew</p>
        <h2 class="mt-3 text-3xl font-semibold text-zinc-900 md:text-4xl">A practice rooted in Africa’s threat and opportunity landscape</h2>
        <p class="mt-4 text-zinc-600">Nangsec’s history is defined by long client relationships, transparent methods, and contributors who still work in live environments.</p>
        <div class="relative mt-8 aspect-[4/3] overflow-hidden rounded-2xl border border-zinc-200 shadow-sm">
          <img src="<%= siteImages.companyTeam %>" alt="Team collaboration" class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
      <div class="space-y-8 lg:col-span-8">
        <% const milestones = [
          { y: "2024", items: ["Published threat notes on payment-fraud chains affecting regional banks", "Expanded vendor-neutral training cohorts with partner universities"] },
          { y: "2021", items: ["Formalized cross-border incident coordination for multinational clients", "Shipped purple-team tooling templates for cloud-native stacks"] },
          { y: "2018", items: ["Stood up red-team and detection engineering under one roof", "Hosted first continent-wide blue-team exercise series"] },
          { y: "2015", items: ["Founded Nangsec with a mandate to pair rigorous testing with local context", "Early work focused on financial services and critical infrastructure"] },
        ]; %>
        <% milestones.forEach(function (m) { %>
        <div class="grid gap-4 border-l-2 border-red-200 pl-6 md:grid-cols-[120px_1fr] md:gap-10">
          <p class="text-2xl font-semibold text-zinc-900"><%= m.y %></p>
          <ul class="space-y-2 text-sm text-zinc-600">
            <% m.items.forEach(function (it) { %>
            <li class="relative"><span class="absolute -left-[29px] top-2 h-2 w-2 rounded-full bg-primary"></span><%= it %></li>
            <% }); %>
          </ul>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="border-b border-zinc-200 bg-white py-16">
    <div class="container">
      <blockquote class="mx-auto max-w-4xl rounded-2xl border border-zinc-200 bg-zinc-50 px-8 py-10 text-center md:px-12">
        <p class="text-xl font-medium leading-relaxed text-zinc-800 md:text-2xl">“Resilience has to work under your regulation, your talent pool, and your uptime reality. Nangsec exists to connect serious engineering discipline with that context.”</p>
        <footer class="mt-8">
          <p class="text-sm font-semibold text-zinc-900">Managing Director, Nangsec Technologies</p>
          <p class="text-xs uppercase tracking-widest text-zinc-500">Leadership</p>
        </footer>
      </blockquote>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">Why teams choose Nangsec</p>
        <h2 class="mt-3 text-3xl font-semibold text-zinc-900 md:text-4xl">Clear ownership, evidence you can trace, and no mystery process</h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <% [{ t: "Depth you can verify", d: "Named engineers on your statements of work, written methodologies, and sample redacted reports before kickoff." },{ t: "Grounded in live environments", d: "Recommendations are filtered through what actually runs in your cloud, data center, and vendor ecosystem." },{ t: "Steady communication", d: "Structured updates for technical owners, risk teams, and executives—without burying anyone in jargon." }].forEach(function (b) { %>
        <div class="rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-zinc-900"><%= b.t %></h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-600"><%= b.d %></p>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="border-t border-zinc-200 bg-zinc-50 py-16 md:py-24">
    <div class="container">
      <div class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">Library</p>
          <h2 class="mt-2 text-3xl font-semibold text-zinc-900">Fresh writing from our consultants</h2>
          <p class="mt-2 text-zinc-600">Short articles you can forward to engineering and risk peers.</p>
        </div>
        <a href="/resources" class="font-semibold text-primary hover:text-red-700">Open resources →</a>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <% const posts = [
          { tag: "Architecture", title: "Layering controls on high-volume APIs", ex: "Rate limits, auth patterns, and abuse detection that survive real traffic.", img: siteImages.cloudSecurity },
          { tag: "Detection", title: "Signal-to-noise in busy SOCs", ex: "Practical triage tweaks our analysts use to protect margin without hiding critical alerts.", img: siteImages.socOperations },
          { tag: "Leadership", title: "Questions boards should ask after a test", ex: "A concise checklist to turn assessment output into funded remediation.", img: siteImages.resourcesDocs },
        ]; %>
        <% posts.forEach(function (post) { %>
        <article class="overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm">
          <div class="relative aspect-[16/10] w-full">
            <img src="<%= post.img %>" alt="" class="h-full w-full object-cover" loading="lazy" />
          </div>
          <div class="p-7">
            <p class="text-xs font-semibold uppercase tracking-widest text-primary"><%= post.tag %></p>
            <h3 class="mt-2 text-lg font-semibold text-zinc-900"><%= post.title %></h3>
            <p class="mt-2 text-sm text-zinc-600"><%= post.ex %></p>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="border-t border-zinc-200 py-16">
    <div class="container">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">Client voices</p>
      <h2 class="mt-2 text-3xl font-semibold text-zinc-900">What partners say after the first renewal cycle</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <% ["The report mapped every finding to an owner and a sprint—our product and infra leads finally shared one backlog.", "Their SOC overlay gave us adult supervision on alerts without forcing us to rip out tooling we had already bought.", "Training felt like internal drills, not certification cramming. Our juniors could explain findings in stand-ups the next day."].forEach(function (quote) { %>
        <div class="rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm">
          <p class="text-sm leading-relaxed text-zinc-700">“<%= quote %>”</p>
          <p class="mt-6 text-sm font-semibold text-zinc-900">Security leadership</p>
          <p class="text-xs text-zinc-500">Technology &amp; finance sectors · names withheld</p>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="border-t border-red-100 bg-gradient-to-r from-red-50 via-white to-red-50 py-16">
    <div class="container text-center">
      <h2 class="text-3xl font-semibold text-zinc-900 md:text-4xl">Tell us what you are trying to defend next</h2>
      <p class="mx-auto mt-3 max-w-2xl text-zinc-600">A scoping call is usually enough to map priorities, constraints, and a first milestone.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/contact" class="btn-primary px-8">Request a consultation</a>
        <a href="/services" class="inline-flex items-center justify-center rounded-md border border-zinc-300 bg-white px-6 py-2.5 text-sm font-semibold text-zinc-900 hover:bg-zinc-50">Review capabilities</a>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot-close') %>
