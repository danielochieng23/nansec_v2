<%- include('partials/head-open') %>
<%- include('partials/nav') %>

<main class="bg-zinc-50">
  <%- include('partials/page-hero', { heroEyebrow: 'Research', heroTitle: title, heroLead: description, heroImage: siteImages.researchDesk, heroImageAlt: 'Researcher analyzing security data and preparing technical notes' }) %>

  <section class="border-b border-zinc-200 bg-white py-8">
    <div class="container flex flex-wrap gap-3">
      <% ["All", "Brief", "Guide", "Note", "Toolkit"].forEach(function (t, i) { %>
      <button type="button" class="rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-widest transition <%= i === 0 ? 'border-primary/40 bg-red-50 text-primary' : 'border-zinc-200 text-zinc-500 hover:border-zinc-300 hover:text-zinc-800' %>"><%= t %></button>
      <% }); %>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% const items = [
        { type: "Brief", title: "Pressure on continent-wide payment switches", abstract: "Observation from exercises and assessments focused on settlement windows and fraud adjacent abuse." },
        { type: "Guide", title: "Standing up detection with limited analysts", abstract: "Triage patterns and tooling choices Nangsec uses when teams cannot yet staff a 24/7 floor." },
        { type: "Note", title: "Signals that precede mobile-wallet takeovers", abstract: "Monitoring and customer-education pairs that reduce account-loss cycles." },
        { type: "Toolkit", title: "Starter queries for multi-cloud estates", abstract: "Baseline queries and tagging rules you can adapt for regulated environments." },
        { type: "Brief", title: "Lateral movement patterns in hybrid workplaces", abstract: "Correlations from tabletop and assumed-breach work with actionable containment ordering." },
        { type: "Guide", title: "Explaining residual risk without hiding behind heatmaps", abstract: "How we translate technical testing into funding decisions leadership can defend." },
      ]; %>
      <% items.forEach(function (item) { %>
      <article class="flex flex-col rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm transition hover:border-red-200 hover:shadow-md">
        <div class="mb-4 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-primary"><%= item.type %></div>
        <h2 class="text-lg font-semibold text-zinc-900"><%= item.title %></h2>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-zinc-600"><%= item.abstract %></p>
        <a href="/contact" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-red-800">Request access →</a>
      </article>
      <% }); %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot-close') %>
