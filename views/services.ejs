<%- include('partials/head-open') %>
<%- include('partials/nav') %>

<main class="bg-zinc-50">
  <%- include('partials/page-hero', { heroEyebrow: 'Services', heroTitle: title, heroLead: description, heroImage: siteImages.servicesHero, heroImageAlt: 'Abstract digital layers representing security assessment and defense depth' }) %>

  <section class="relative border-b border-zinc-800 bg-zinc-950 py-14 md:py-16">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_-20%,rgba(220,38,38,0.15),transparent_55%)]"></div>
    <div class="relative container">
      <p class="text-center text-xs font-semibold uppercase tracking-[0.22em] text-red-400">How we work with you</p>
      <p class="mx-auto mt-3 max-w-2xl text-center text-sm leading-relaxed text-zinc-400">Every engagement starts with scope, threat context, and success criteria you can measure. We align testing, monitoring, and advisory so findings roll into the same remediation rhythm—not disconnected PDFs.</p>
      <div class="mt-10 grid gap-6 border-t border-white/10 pt-10 sm:grid-cols-3">
        <% [{ t: "Named leads", d: "A single practice owner coordinates deliverables, dates, and readouts for technical and executive audiences." },{ t: "Evidence you can reuse", d: "Artifacts map to controls, tickets, and audit requests so GRC and engineering share one backlog." },{ t: "Regional context", d: "Delivery across West and East Africa with playbooks tuned to regulators and sector norms you actually face." }].forEach(function (x) { %>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
          <p class="text-sm font-semibold text-white"><%= x.t %></p>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400"><%= x.d %></p>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <% const catImages = { assessment: siteImages.networkAbstract, managed: siteImages.socOperations, specialized: siteImages.servicesHero, compliance: siteImages.resourcesDocs }; %>
  <% categoriesWithServices.forEach(function (cat, idx) { var img = catImages[cat.id] || siteImages.cloudSecurity; var flip = idx % 2 === 1; %>
  <section id="<%= cat.id %>" class="scroll-mt-28 border-b border-zinc-200 <%= idx % 2 === 0 ? 'bg-white' : 'bg-zinc-50' %> py-16 md:py-24">
    <div class="container">
      <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16 <%= flip ? 'lg:flex-row-reverse' : '' %>">
        <div class="<%= flip ? 'lg:order-2' : '' %>">
          <span class="inline-flex items-center rounded-full border border-red-200 bg-red-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-widest text-primary"><%= cat.id.replace(/-/g, ' ') %></span>
          <h2 class="mt-4 text-balance text-2xl font-semibold tracking-tight text-zinc-900 md:text-3xl lg:text-4xl"><%= cat.title %></h2>
          <p class="mt-4 text-base leading-relaxed text-zinc-600 md:text-lg"><%= cat.subtitle %></p>
          <p class="mt-5 text-sm leading-relaxed text-zinc-500">Each offering below links to a detail page with deliverables and typical cadence. Mix offerings under one steering group when you need testing and operations to share evidence.</p>
        </div>
        <div class="<%= flip ? 'lg:order-1' : '' %> relative overflow-hidden rounded-2xl border border-zinc-200 shadow-lg ring-1 ring-zinc-100">
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          <img src="<%= img %>" alt="" class="aspect-[4/3] w-full object-cover object-center" loading="lazy" />
        </div>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        <% cat.items.forEach(function (s, si) { %>
        <article class="group relative overflow-hidden rounded-2xl border border-zinc-200 bg-white p-7 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:border-red-200 hover:shadow-md md:p-8">
          <span class="text-xs font-mono text-zinc-400"><%= String(si + 1).padStart(2, '0') %></span>
          <h3 class="mt-2 text-xl font-semibold text-zinc-900"><%= s.title %></h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-600"><%= s.summary %></p>
          <ul class="mt-5 space-y-2.5 text-sm text-zinc-600">
            <% s.bullets.forEach(function (b) { %>
            <li class="flex gap-2"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary"></span><span><%= b %></span></li>
            <% }); %>
          </ul>
          <div class="mt-8 flex flex-wrap gap-4 border-t border-zinc-100 pt-6 text-sm font-semibold">
            <a href="/services/<%= s.slug %>" class="inline-flex items-center gap-1 text-primary transition group-hover:gap-2">View details →</a>
            <a href="/contact" class="text-zinc-500 hover:text-primary">Schedule a call</a>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </section>
  <% }); %>

  <section class="border-t border-red-100 bg-gradient-to-r from-red-50 via-white to-red-50 py-16 md:py-20">
    <div class="container grid gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">Multi-track programs</p>
        <h2 class="mt-3 text-2xl font-semibold text-zinc-900 md:text-3xl">Need several workstreams under one steering group?</h2>
        <p class="mt-4 text-sm leading-relaxed text-zinc-600">We combine assessments, SOC overlay, tabletop exercises, and training under one operating plan—with joint milestones and a single risk narrative for leadership.</p>
        <ul class="mt-6 space-y-2 text-sm text-zinc-600">
          <li class="flex gap-2"><span class="text-primary">→</span> Sample governance calendar and RACI template on request</li>
          <li class="flex gap-2"><span class="text-primary">→</span> Shared ticketing and evidence hooks for ISO, SOC 2, and NDPR-style reviews</li>
        </ul>
      </div>
      <div class="rounded-2xl border border-red-100 bg-white p-8 shadow-sm">
        <p class="text-sm font-medium text-zinc-900">Talk through your estate and constraints—we will map a first milestone in one call.</p>
        <a href="/contact" class="btn-primary mt-6 inline-flex w-full justify-center sm:w-auto">Plan a scoping call</a>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot-close') %>
