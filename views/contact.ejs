<%- include('partials/head-open') %>
<%- include('partials/nav') %>

<main class="bg-zinc-50">
  <%- include('partials/page-hero', { heroEyebrow: heroEyebrow, heroTitle: heroTitle, heroLead: heroLead, heroImage: siteImages.contactOffice, heroImageAlt: 'Professional office environment for client consultations' }) %>

  <section class="border-b border-zinc-200 py-14 md:py-20">
    <div class="container grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <% if (sent) { %>
        <p class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">Message received—we will reply within one business day.</p>
        <% } %>
        <% if (error) { %>
        <p class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">Please fill in all fields. Message must be at least 10 characters.</p>
        <% } %>
        <form method="post" action="/contact" class="space-y-5">
          <div>
            <label class="text-sm font-medium text-zinc-700" for="name">Name</label>
            <input id="name" name="name" required class="mt-2 w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm outline-none transition focus:border-primary/50 focus:ring-2 focus:ring-red-100" />
          </div>
          <div>
            <label class="text-sm font-medium text-zinc-700" for="email">Work email</label>
            <input id="email" name="email" type="email" required class="mt-2 w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm outline-none transition focus:border-primary/50 focus:ring-2 focus:ring-red-100" />
          </div>
          <div>
            <label class="text-sm font-medium text-zinc-700" for="message">What should we know?</label>
            <textarea id="message" name="message" rows="6" required minlength="10" class="mt-2 w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm outline-none transition focus:border-primary/50 focus:ring-2 focus:ring-red-100"></textarea>
          </div>
          <button type="submit" class="w-full rounded-md bg-primary px-4 py-3 text-sm font-semibold text-white shadow-md shadow-red-200/80 transition hover:bg-red-600 sm:w-auto sm:px-8">Submit</button>
        </form>
      </div>

      <aside class="space-y-6 lg:col-span-5">
        <div class="rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-widest text-primary">Contact channels</p>
          <ul class="mt-6 space-y-5 text-sm text-zinc-700">
            <li class="flex gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href="tel:+2348000000000" class="hover:text-zinc-900">+234 800 000 0000</a>
            </li>
            <li class="flex gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href="mailto:info@nangsec.africa" class="hover:text-zinc-900">info@nangsec.africa</a>
            </li>
            <li class="flex gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span>Lagos · Nairobi · Accra</span>
            </li>
          </ul>
        </div>
        <div class="h-72 overflow-hidden rounded-2xl border border-zinc-200 shadow-sm">
          <iframe title="Office map" class="h-full w-full" src="https://www.openstreetmap.org/export/embed.html?bbox=3.2%2C6.3%2C3.5%2C6.7&layer=mapnik"></iframe>
        </div>
      </aside>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot-close') %>
