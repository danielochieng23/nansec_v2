<%- include('partials/head-open') %>
<%- include('partials/nav') %>

<main class="bg-zinc-50">
  <%- include('partials/page-hero', { heroEyebrow: 'Training', heroTitle: title, heroLead: description, heroImage: siteImages.trainingLab, heroImageAlt: 'Instructor-led cybersecurity lab and skills development' }) %>

  <section class="relative border-b border-red-100 bg-red-50">
    <div class="container grid gap-10 py-14 md:grid-cols-2 md:items-center md:py-16">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">Practice-linked curriculum</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-zinc-900 md:text-3xl">Built by consultants who still run live programs</h2>
        <p class="mt-4 text-sm leading-relaxed text-zinc-700">Labs use the same log formats, playbooks, and debrief patterns we apply on client work—so skills transfer to your tickets and war rooms, not just slide decks.</p>
      </div>
      <div class="overflow-hidden rounded-2xl border border-red-100/80 shadow-md ring-1 ring-red-100/50">
        <img src="<%= siteImages.trainingLab %>" alt="Hands-on lab environment" class="aspect-video w-full object-cover object-center" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="border-b border-zinc-200 bg-white py-14">
    <div class="container">
      <p class="text-center text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">What you get</p>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <% [{ k: "Instructors", v: "Consultants who split time between classrooms and customer engagements—less theory drift and more grounded scenarios.", bullets: ["Office hours during cohorts", "Optional capstone reviews"] },{ k: "Labs", v: "Shared sandboxes with realistic logs, detection pipelines, and facilitator debriefs tied to measurable objectives.", bullets: ["Branded playbooks you can adapt", "Capture-the-flag style checkpoints"] },{ k: "Outcomes", v: "Skills matrices you can hand to hiring managers or map into existing competency frameworks.", bullets: ["Role-based learning paths", "Executive summaries for sponsors"] }].forEach(function (x) { %>
        <div class="flex flex-col rounded-2xl border border-zinc-200 bg-zinc-50/80 p-7 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-widest text-primary"><%= x.k %></p>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-zinc-600"><%= x.v %></p>
          <ul class="mt-5 space-y-2 border-t border-zinc-200/80 pt-5 text-xs text-zinc-500">
            <% x.bullets.forEach(function (b) { %>
            <li class="flex gap-2"><span class="text-primary">+</span><%= b %></li>
            <% }); %>
          </ul>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="border-b border-zinc-200 py-16 md:py-24">
    <div class="container">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">Programs</p>
        <h2 class="mt-2 text-3xl font-semibold text-zinc-900 md:text-4xl">Formats we deliver</h2>
        <p class="mt-3 text-sm text-zinc-600">Pick public cohorts, private classes, or university-backed tracks—then layer certifications or custom scenarios.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <% const tracks = [
          { title: "Professional certifications", desc: "Focused prep and labs aligned to the skills employers verify in technical interviews—not empty certificate mills.", extras: ["Exam strategy sessions", "Pairing with mentors from our testing practice"], cta: "Request syllabus", href: "/contact" },
          { title: "Academic partnerships", desc: "Semester-style tracks, capstones, and mentor reviews co-developed with faculty when programs need depth beyond a single elective.", extras: ["Guest lectures from incident leads", "Open-source lab bundles"], cta: "Academic inquiry", href: "/contact" },
          { title: "Intensive bootcamps", desc: "Short, high-touch sprints for SOC triage, offensive fundamentals, and cloud security basics with daily facilitator feedback.", extras: ["Evening options for busy teams", "Post-boot skills survey"], cta: "See upcoming dates", href: "/contact" },
          { title: "Corporate learning", desc: "Private classes for product engineers, IT, GRC, and executives—with scenarios sampled from your control vocabulary where appropriate.", extras: ["Tabletop overlays", "Recorded recap for LMS"], cta: "Shape a cohort", href: "/contact" },
        ]; %>
        <% tracks.forEach(function (t) { %>
        <div class="group flex flex-col rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm transition hover:border-red-200 hover:shadow-md">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-zinc-100 bg-zinc-50 text-primary">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-zinc-900"><%= t.title %></h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-600"><%= t.desc %></p>
          <ul class="mt-5 space-y-1.5 text-xs text-zinc-500">
            <% t.extras.forEach(function (ex) { %>
            <li>• <%= ex %></li>
            <% }); %>
          </ul>
          <a href="<%= t.href %>" class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-primary group-hover:gap-3"><%= t.cta %> →</a>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="bg-gradient-to-b from-white to-zinc-50 py-14">
    <div class="container grid gap-8 lg:grid-cols-2">
      <div class="rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm md:p-10">
        <h2 class="text-xl font-semibold text-zinc-900">Who we train</h2>
        <ul class="mt-6 space-y-4 text-sm text-zinc-600">
          <li class="flex gap-3"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>SOC analysts moving from tier-1 triage to hunting and detection engineering.</li>
          <li class="flex gap-3"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>Platform and product engineers hardening cloud and API surfaces before release.</li>
          <li class="flex gap-3"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>Risk and IT leaders who need shared vocabulary with engineering—without drowning in jargon.</li>
        </ul>
      </div>
      <div class="flex flex-col justify-center rounded-2xl border border-red-100 bg-gradient-to-br from-red-50 to-white p-8 shadow-sm md:p-10">
        <h2 class="text-xl font-semibold text-zinc-900">Schedules</h2>
        <p class="mt-3 text-sm leading-relaxed text-zinc-600">We publish open seats quarterly and schedule private cohorts around your release calendar. Ask for a geography-specific calendar if you operate across multiple hubs.</p>
        <a href="/contact" class="btn-primary mt-8 inline-flex w-fit">Ask for a calendar</a>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot-close') %>
