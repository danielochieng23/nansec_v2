<%- include('partials/head-open') %>
<%- include('partials/nav') %>

<main class="bg-white">
  <%- include('partials/page-hero', { heroEyebrow: 'Training', heroTitle: title, heroLead: description, heroImage: siteImages.trainingLab, heroImageAlt: 'Instructor-led cybersecurity lab and skills development' }) %>

  <section class="border-b border-zinc-200 bg-zinc-50 py-14">
    <div class="container grid gap-6 lg:grid-cols-3">
      <% [{ k: "Instructors", v: "Consultants who split time between classrooms and customer engagements—less theory drift." },{ k: "Labs", v: "Shared sandboxes with realistic logs, playbooks, and debriefs tied to measurable objectives." },{ k: "Outcomes", v: "Skills matrices you can hand to hiring managers or map into existing competency frameworks." }].forEach(function (x) { %>
      <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary"><%= x.k %></p>
        <p class="mt-3 text-sm leading-relaxed text-zinc-600"><%= x.v %></p>
      </div>
      <% }); %>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">Programs</p>
        <h2 class="mt-2 text-3xl font-semibold text-zinc-900 md:text-4xl">Pick the format that fits your organization</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <% const tracks = [
          { title: "Professional certifications", desc: "Focused prep and labs aligned to the skills employers verify during technical interviews—not empty certificate mills.", cta: "Request syllabus", href: "/contact" },
          { title: "Academic partnerships", desc: "Semester-style tracks, capstones, and mentor reviews co-developed with faculty.", cta: "Academic inquiry", href: "/contact" },
          { title: "Intensive bootcamps", desc: "Short, high-touch sprints for SOC triage, offsec fundamentals, and cloud security basics.", cta: "See upcoming dates", href: "/contact" },
          { title: "Corporate learning", desc: "Private classes for product engineers, IT, GRC, and executives.", cta: "Shape a cohort", href: "/contact" },
        ]; %>
        <% tracks.forEach(function (t) { %>
        <div class="group flex flex-col rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm transition hover:border-red-200 hover:shadow-md">
          <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-zinc-100 bg-zinc-50 text-primary">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-zinc-900"><%= t.title %></h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-zinc-600"><%= t.desc %></p>
          <a href="<%= t.href %>" class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-red-800"><%= t.cta %> →</a>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="border-t border-red-100 bg-gradient-to-r from-red-50 via-white to-red-50 py-14">
    <div class="container flex flex-col items-start justify-between gap-6 rounded-2xl border border-red-100 bg-white/80 p-8 shadow-sm md:flex-row md:items-center md:p-10">
      <div>
        <h2 class="text-2xl font-semibold text-zinc-900">Public schedule &amp; closed cohorts</h2>
        <p class="mt-2 max-w-2xl text-sm text-zinc-600">We rotate open seats quarterly and schedule private deliveries around your release calendar.</p>
      </div>
      <a href="/contact" class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-semibold text-white shadow-md shadow-red-200/80 transition hover:bg-red-600">Ask for a calendar</a>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot-close') %>
